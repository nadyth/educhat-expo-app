{
  "expo": {
    "name": "EduChat AI",
    "slug": "edu-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "educhat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.devnadeem.educhat"
    },
    "android": {
      "package": "com.devnadeem.educhat",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#1E3A8A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1E3A8A",
          "dark": {
            "backgroundColor": "#1E3A8A"
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosClientId": "597120914452-2kkuuts4k4330pvm9b2t0vj8ii2qaa59.apps.googleusercontent.com",
          "iosUrlScheme": "com.googleusercontent.apps.597120914452-2kkuuts4k4330pvm9b2t0vj8ii2qaa59"
        }
      ]
    ],
    "extra": {
      "googleWebClientId": "597120914452-len0a0qk1eb24q2jsfc9r8tkdr0t49ir.apps.googleusercontent.com",
      "googleIosClientId": "597120914452-2kkuuts4k4330pvm9b2t0vj8ii2qaa59.apps.googleusercontent.com",
      "router": {}
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
